# Python virtual environment
.venv/

# Python bytecode caches (e.g. scripts/__pycache__)
__pycache__/
*.py[cod]

# ABC interactive command history (created when running graduate-abc / abc)
abc.history

# Generated run artifacts (ABC flows, match dumps, reports)
output/

# Local CMake build tree (mo_techmap and embedded mockturtle libs)
build/

# Local symlinks to external resources (not tracked)
third_party/benchmarks
third_party/asap7_lib

# Extracted ASAP7 liberty files (large, derived from asap7_lib)
third_party/asap7_RVT_FF_nldm/
